# --- Supabase ---
# From your Supabase project settings (provision in ap-southeast-1 / Singapore for PH latency).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (transactional email) ---
# Leave RESEND_API_KEY empty to run in "log only" mode: emails are written to the
# email_log table + console and the network send is skipped.
RESEND_API_KEY=
EMAIL_FROM="Fourhand Tennis Club <bookings@fourhand.example>"
STAFF_EMAIL=staff@fourhand.example

# --- Cron ---
# Shared secret guarding /api/cron/* route handlers (Vercel Cron sends this).
CRON_SECRET=replace-with-a-long-random-string

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
